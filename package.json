{
  "name": "@atomic-react-exploration/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "precommit:format": "FILES=\"$(git diff --name-only --cached)\"; [ -z \"$FILES\" ] || npx nx format:check --files=\"$FILES\"",
    "precommit:affected": "FILES=\"$(git diff --name-only --cached)\"; [ -z \"$FILES\" ] || npx nx affected -t lint,test,build,typecheck --files=\"$FILES\" --nxBail",
    "precommit:all": "npm run precommit:format && npm run precommit:affected",
    "prepush:all": "npx nx format:check && npx nx run-many -t lint,test,build,typecheck --all --nxBail",
    "storybook": "CI=1 STORYBOOK_DISABLE_TELEMETRY=1 npx nx run-many -t storybook --all --nxBail",
    "build-storybook": "CI=1 STORYBOOK_DISABLE_TELEMETRY=1 npx nx run-many -t build-storybook --all --nxBail"
  },
  "private": true,
  "devDependencies": {
    "@babel/core": "^7.14.5",
    "@babel/preset-react": "^7.14.5",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.8.0",
    "@nx/eslint": "^22.6.4",
    "@nx/eslint-plugin": "22.6.4",
    "@nx/js": "22.6.4",
    "@nx/react": "^22.6.4",
    "@nx/storybook": "22.6.4",
    "@nx/vite": "22.6.4",
    "@nx/vitest": "22.6.4",
    "@nx/web": "22.6.4",
    "@nx/workspace": "22.6.4",
    "@storybook/react-vite": "^10.1.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-is": "^19.0.0",
    "@types/styled-components": "5.1.26",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "~4.1.0",
    "@vitest/ui": "~4.1.0",
    "ajv": "^8.0.0",
    "babel-plugin-styled-components": "1.10.7",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "husky": "^9.1.7",
    "jest-styled-components": "^7.4.0",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "nx": "22.6.4",
    "prettier": "~3.6.2",
    "storybook": "^10.1.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "~4.5.0",
    "vitest": "~4.1.0"
  },
  "dependencies": {
    "@fontsource/quicksand": "^5.2.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-is": "^19.0.0",
    "styled-components": "5.3.6"
  }
}
