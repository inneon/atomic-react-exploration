{
  "name": "templates",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/templates/src",
  "projectType": "library",
  "tags": ["type:template"],
  "// targets": "to see all targets run: nx show project templates --web",
  "targets": {
    "storybook": {
      "executor": "@nx/storybook:storybook",
      "options": {
        "configDir": "libs/templates/.storybook",
        "port": 6009,
        "exactPort": true,
        "host": "localhost"
      }
    }
  }
}
